[0m13:01:22.278893 [debug] [Thread-1 (]: On model.aemo_energy.stg_price_and_demand: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "aemo_energy", "target_name": "dev", "node_id": "model.aemo_energy.stg_price_and_demand"} */

  
  create view "dev"."main_staging"."stg_price_and_demand__dbt_tmp" as (
    -- models/staging/stg_price_and_demand.sql
-- Silver layer: clean and standardise AEMO price & demand data from Bronze

with source as (

    select * from "dev"."main"."price_and_demand"

),

cleaned as (

    select
        -- Region
        "REGION"                                        as region_id,

        -- Timestamps
        strptime("SETTLEMENTDATE", '%Y/%m/%d %H:%M:%S') as settlement_ts,
        date_trunc('day',
            strptime("SETTLEMENTDATE", '%Y/%m/%d %H:%M:%S'))  as settlement_date,
        date_trunc('month',
            strptime("SETTLEMENTDATE", '%Y/%m/%d %H:%M:%S'))  as settlement_month,
        extract('hour' from
            strptime("SETTLEMENTDATE", '%Y/%m/%d %H:%M:%S'))  as hour_of_day,

        -- Peak / off-peak classification
        case
            when extract('hour' from
                strptime("SETTLEMENTDATE", '%Y/%m/%d %H:%M:%S'))
                between 7 and 21
            then 'peak'
            else 'off_peak'
        end                                             as time_of_use_band,

        -- Price & demand
        "RRP"                                           as rrp_aud_mwh,
        "TOTALDEMAND"                                   as total_demand_mw,
        "PERIODTYPE"                                    as period_type,

        -- Spike flag (>$300/MWh is considered a price spike in NEM)
        case when "RRP" > 300 then true else false end  as is_price_spike,

        -- Metadata
        "_ingested_at"                                  as ingested_at

    from source
    where "RRP" is not null
      and "TOTALDEMAND" is not null

)

select * from cleaned
  );

